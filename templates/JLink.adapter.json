{
    "launch": {
        "singlecore-launch": {
            "name": "JLink (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files[0]?.file || '' %>",
            "gdb": "arm-none-eabi-gdb",
            "preLaunchTask": "CMSIS Load",
            "initCommands": [
                "<% const files = symbol_files.slice(1).map(s => s.file) %>",
                "<% for (const file of files) { %>",
                "symbol-file <%= file %>\n",
                "<% } %>",
                "<% const resetTypes = [ %>",
                "<%   { name: 'Normal', argument: 0 }, %>",
                "<%   { name: 'Core', argument: 1 }, %>",
                "<%   { name: 'Reset Pin', argument: 2 }, %>",
                "<% ] %>",
				"<% const resetType = resetTypes.find(type => type.name === config.reset) %>",
                "monitor reset <%= resetType?.argument ?? '' %>\n",
                "<% if (config.trace && config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "monitor SWO EnableTarget 0 <%= config.trace?.[\"trace-clock\"] ?? '12000' %> 1 0",
                "<% } %>",
                "tbreak main"
            ],
            "customResetCommands": [
                "<% const resetTypes = [ %>",
                "<%   { name: 'Normal', argument: 0 }, %>",
                "<%   { name: 'Core', argument: 1 }, %>",
                "<%   { name: 'Reset Pin', argument: 2 }, %>",
                "<% ] %>",
				"<% const resetType = resetTypes.find(type => type.name === config.reset) %>",
                "monitor reset <%= resetType?.argument ?? '' %>\n",
                "tbreak main",
                "continue"
            ],
            "target": {
                "server": "JLinkGDBServerCL<%= platform === 'win32' ? '.exe' : '' %>",
                "serverParameters": [
                    "-device", "<%= device_name %>\n",
                    "-endian", "little",
                    "-if", "<%= config.protocol ?? 'swd' %>\n",
                    "-speed", "<%= config.clock ? parseInt(config.clock / 1000) : '4000' %>\n",
                    "-noir",
                    "-vd",
                    "-nogui",
                    "-localhostonly",
                    "-port", "<%= ports.get(pname) %>\n",
                    "<% if (config.trace && config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                    "-SWOPort",
                    "<%= config.trace?.[\"trace-port\"] ?? '5555' %>\n",
                    "<% } %>",
                    "<% if (config.telnet) { %>",
                    "-TelnetPort",
                    "<%= config.telnet?.port ?? '4444' %>\n",
                    "<% } %>"
                ],
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        "singlecore-attach": {
            "name": "JLink (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files[0]?.file || '' %>",
