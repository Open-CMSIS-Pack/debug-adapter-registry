{
    "data": {
        "osShellOptions": {
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/d", "/c" ]
                    }
                }
            },
            "linux": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "osx": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            }
        },
        "defaultDebugClock": 4000000,
        "debugClockScaler": 1000,
        "defaultResetType": 0,
        "resetTypes": {
            "Normal": 0,
            "Core": 1,
            "Reset Pin": 2
        },
        // TODO: null not working as assumed
        "defaultTerminalPortOption": null,
        "terminalPortOptions": {
            "Disabled": null,
            "Semihosting": "TelnetPort",
            "SWO": "TelnetPort",
            "RTT": "RTTTelnetPort"
        },
        "defaultTerminalPort": "4444",
        "defaultSWOPort": "5555",
        "defaultTraceClock": 12000
    },
    "launch": {
        "singlecore-launch": {
            "name": "JLink (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files[0]?.file || '' %>",
            "gdb": "arm-none-eabi-gdb",
            "preLaunchTask": "CMSIS Load",
            "initCommands": [
                "<% symbol_files.slice(1).map(s => s.file).forEach(file => { %>",
                "symbol-file <%= file %>\n",
                "<% }) %>",
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "monitor SWO EnableTarget 0 <%= config.trace?.[\"trace-clock\"] ?? data.defaultTraceClock %> 1 0",
                "<% } %>",
                "tbreak main"
            ],
            "customResetCommands": [
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "tbreak main",
                "continue"
            ],
            "target": {
                "server": "JLinkGDBServerCL<%= platform === 'win32' ? '.exe' : '' %>",
                "serverParameters": [
                    "-device", "<%= device_name %>\n",
                    "-endian", "little",
                    "-if", "<%= config.protocol ?? 'swd' %>\n",
                    "-speed", "<%= parseInt((config.clock ?? data.defaultDebugClock) / data.debugClockScaler) %>\n",
                    "-noir",
                    "-vd",
                    "-nogui",
                    "-localhostonly",
                    "-port", "<%= ports.get(pname) %>\n",
                    "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                    "-SWOPort",
                    "<%= config.trace?.[\"trace-port\"] ?? data.defaultSWOPort %>\n",
                    "<% } %>",
                    "<% if (data.terminalPortOptions[config.terminal?.mode]) { %>",
                    "-<%= data.terminalPortOptions[config.terminal?.mode] %>\n",
                    "<%= config.terminal?.port ?? data.defaultTerminalPort %>\n",
                    "<% } %>"
                ],
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        "singlecore-attach": {
            "name": "JLink (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files[0]?.file || '' %>",
            "gdb": "arm-none-eabi-gdb",
            "initCommands": [
                "<% symbol_files.slice(1).map(s => s.file).forEach(file => { %>",
                "symbol-file <%= file %>\n",
                "<% }) %>",
                "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "monitor SWO EnableTarget 0 <%= config.trace?.[\"trace-clock\"] ?? data.defaultTraceClock %> 1 0",
                "<% } %>"
            ],
            "customResetCommands": [
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "tbreak main",
                "continue"
            ],
            "target": {
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        "multicore-start-launch": {
            "name": "<%= pname %> JLink (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files.filter(s => s.pname === pname)[0]?.file || '' %>",
            "gdb": "arm-none-eabi-gdb",
            "preLaunchTask": "CMSIS Load",
            "initCommands": [
                "<% const files = symbol_files.filter(s => s.pname === pname).slice(1).map(s => s.file).forEach(file => { %>",
                "symbol-file <%= file %>\n",
                "<% }) %>",
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "monitor SWO EnableTarget 0 <%= config.trace?.[\"trace-clock\"] ?? data.defaultTraceClock %> 1 0",
                "<% } %>",
                "tbreak main"
            ],
            "customResetCommands": [
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "tbreak main",
                "continue"
            ],
            "target": {
                "server": "JLinkGDBServerCL<%= platform === 'win32' ? '.exe' : '' %>",
                "serverParameters": [
                    "-device", "<%= device_name %>_<%= pname %>\n",
                    "-endian", "little",
                    "-if", "<%= config.protocol ?? 'swd' %>\n",
                    "-speed", "<%= parseInt((config.clock ?? data.defaultDebugClock) / data.debugClockScaler) %>\n",
                    "-noir",
                    "-vd",
                    "-nogui",
                    "-localhostonly",
                    "-port", "<%= ports.get(pname) %>\n",
                    "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                    "-SWOPort",
                    "<%= config.trace?.[\"trace-port\"] ?? data.defaultSWOPort %>\n",
                    "<% } %>",
                    "<% if (data.terminalPortOptions[config.terminal?.mode]) { %>",
                    "-<%= data.terminalPortOptions[config.terminal?.mode] %>\n",
                    "<%= config.terminal?.port ?? data.defaultTerminalPort %>\n",
                    "<% } %>"
                ],
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        "multicore-start-attach": {
            "name": "<%= pname %> JLink (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files.filter(s => s.pname === pname)[0]?.file || '' %>",
            "gdb": "arm-none-eabi-gdb",
            "initCommands": [
                "<% const files = symbol_files.filter(s => s.pname === pname).slice(1).map(s => s.file).forEach(file => { %>",
                "symbol-file <%= file %>\n",
                "<% }) %>",
                "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "monitor SWO EnableTarget 0 <%= config.trace?.[\"trace-clock\"] ?? data.defaultTraceClock %> 1 0",
                "<% } %>"
            ],
            "customResetCommands": [
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "tbreak main",
                "continue"
            ],
            "target": {
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        "multicore-other": {
            "name": "<%= pname %> JLink (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}/<%= solution_folder %>",
            "program": "<%= symbol_files.filter(s => s.pname === pname)[0]?.file || '' %>",
            "gdb": "arm-none-eabi-gdb",
            "initCommands": [
                "<% const files = symbol_files.filter(s => s.pname === pname).slice(1).map(s => s.file).forEach(file => { %>",
                "symbol-file <%= file %>\n",
                "<% }) %>",
                "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "monitor SWO EnableTarget 0 <%= config.trace?.[\"trace-clock\"] ?? data.defaultTraceClock %> 1 0",
                "<% } %>"
            ],
            "customResetCommands": [
                "monitor reset <%= data.resetTypes[config.reset] ?? data.defaultResetType %>\n",
                "tbreak main",
                "continue"
            ],
            "target": {
                "server": "JLinkGDBServerCL<%= platform === 'win32' ? '.exe' : '' %>",
                "serverParameters": [
                    "-device", "<%= device_name %>_<%= pname %>\n",
                    "-endian", "little",
                    "-if", "<%= config.protocol ?? 'swd' %>\n",
                    "-speed", "<%= parseInt((config.clock ?? data.defaultDebugClock) / data.debugClockScaler) %>\n",
                    "-noir",
                    "-vd",
                    "-nogui",
                    "-localhostonly",
                    "-port", "<%= ports.get(pname) %>\n",
                    "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                    "-SWOPort",
                    "<%= config.trace?.[\"trace-port\"] ?? data.defaultSWOPort %>\n",
                    "<% } %>",
                    "<% if (data.terminalPortOptions[config.terminal?.mode]) { %>",
                    "-<%= data.terminalPortOptions[config.terminal?.mode] %>\n",
                    "<%= config.terminal?.port ?? data.defaultTerminalPort %>\n",
                    "<% } %>"
                ],
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        }
    },
    "tasks": [
        {
            "label": "CMSIS Erase",
            "type": "shell",
            "command": [
                "echo Connect > .cmd.jlink &&",
                "echo Erase >> .cmd.jlink &&",
                "echo Exit >> .cmd.jlink &&",
                "JLink<%= platform === 'win32' ? '.exe' : 'Exe' %> -device <%= device_name %><%= start_pname ? `_${start_pname}` : '' %> -if <%= config.protocol ?? 'swd' %> -speed <%= parseInt((config.clock ?? data.defaultDebugClock) / data.debugClockScaler) %> -commandfile .cmd.jlink"
            ],
            "options": { "cwd": "${workspaceFolder}/<%= solution_folder %>" },
            "windows": "<%= JSON.stringify(data.osShellOptions.windows) %>",
            "linux": "<%= JSON.stringify(data.osShellOptions.linux) %>",
            "osx": "<%= JSON.stringify(data.osShellOptions.osx) %>",
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load",
            "type": "shell",
            "command": [
                "echo Connect > .cmd.jlink &&",
                "<% for (const image of image_files) { %>",
                "echo LoadFile \"<%= image.file %>\" >> .cmd.jlink &&",
                "<% } %>",
                "echo Exit >> .cmd.jlink &&",
                "JLink<%= platform === 'win32' ? '.exe' : 'Exe' %> -device <%= device_name %><%= start_pname ? `_${start_pname}` : '' %> -if <%= config.protocol ?? 'swd' %> -speed <%= parseInt((config.clock ?? data.defaultDebugClock) / data.debugClockScaler) %> -commandfile .cmd.jlink"
            ],
            "options": { "cwd": "${workspaceFolder}/<%= solution_folder %>" },
            "windows": "<%= JSON.stringify(data.osShellOptions.windows) %>",
            "linux": "<%= JSON.stringify(data.osShellOptions.linux) %>",
            "osx": "<%= JSON.stringify(data.osShellOptions.osx) %>",
            "problemMatcher": []
        },
        {
            "label": "CMSIS Run",
            "type": "shell",
            "command": "JLinkGDBServerCL<%= platform === 'win32' ? '.exe' : '' %>",
            "options": { "cwd": "${workspaceFolder}/<%= solution_folder %>" },
            "windows": "<%= JSON.stringify(data.osShellOptions.windows) %>",
            "linux": "<%= JSON.stringify(data.osShellOptions.linux) %>",
            "osx": "<%= JSON.stringify(data.osShellOptions.osx) %>",
            "args": [
                "-device", "<%= device_name %><%= start_pname ? `_${start_pname}` : '' %>\n",
                "-endian", "little",
                "-if", "<%= config.protocol ?? 'swd' %>\n",
                "-speed", "<%= parseInt((config.clock ?? data.defaultDebugClock) / data.debugClockScaler) %>\n",
                "-nohalt",
                "-noir",
                "-nogui",
                "-localhostonly",
                "-port", "<%= ports.get(start_pname) %>\n",
                "<% if (config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "-SWOPort", "<%= config.trace?.[\"trace-port\"] ?? data.defaultSWOPort %>\n",
                "<% } %>",
                "<% if (data.terminalPortOptions[config.terminal?.mode]) { %>",
                "-<%= data.terminalPortOptions[config.terminal?.mode] %>\n",
                "<%= config.terminal?.port ?? data.defaultTerminalPort %>\n",
                "<% } %>"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load+Run",
            "dependsOn": [
                "CMSIS Load",
                "CMSIS Run"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
