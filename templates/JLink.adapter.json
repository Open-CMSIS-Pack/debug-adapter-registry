    },
    "tasks": [
        {
            "label": "CMSIS Erase",
            "type": "shell",
            "command": [
                "echo Connect > .cmd.jlink &&",
                "echo Erase >> .cmd.jlink &&",
                "echo Exit >> .cmd.jlink &&",
                "JLink<%= platform === 'win32' ? '.exe' : 'Exe' %> -device <%= device_name %><%= start_pname ? `_${start_pname}` : '' %> -if <%= config.protocol ?? 'swd' %> -speed <%= config.clock ? parseInt(config.clock / 1000) : '4000' %> -commandfile .cmd.jlink"
            ],
            "options": { "cwd": "${workspaceFolder}/<%= solution_folder %>" },
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/d", "/c" ]
                    }
                }
            },
            "linux": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "osx": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load",
            "type": "shell",
            "command": [
                "echo Connect > .cmd.jlink &&",
                "<% for (const image of image_files) { %>",
                "echo LoadFile \"<%= image.file %>\" >> .cmd.jlink &&",
                "<% } %>",
                "echo Exit >> .cmd.jlink &&",
                "JLink<%= platform === 'win32' ? '.exe' : 'Exe' %> -device <%= device_name %><%= start_pname ? `_${start_pname}` : '' %> -if <%= config.protocol ?? 'swd' %> -speed <%= config.clock ? parseInt(config.clock / 1000) : '4000' %> -commandfile .cmd.jlink"
            ],
            "options": { "cwd": "${workspaceFolder}/<%= solution_folder %>" },
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/d", "/c" ]
                    }
                }
            },
            "linux": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "osx": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "problemMatcher": []
        },
        {
            "label": "CMSIS Run",
            "type": "shell",
            "command": "JLinkGDBServerCL<%= platform === 'win32' ? '.exe' : '' %>",
            "options": { "cwd": "${workspaceFolder}/<%= solution_folder %>" },
            "windows": {
                "options": {
                    "shell": {
                        "executable": "cmd.exe",
                        "args": [ "/d", "/c" ]
                    }
                }
            },
            "linux": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "osx": {
                "options": {
                    "shell": {
                        "executable": "/bin/bash",
                        "args": [ "-c" ]
                    }
                }
            },
            "args": [
                "-device", "<%= device_name %><%= start_pname ? `_${start_pname}` : '' %>\n",
                "-endian", "little",
                "-if", "<%= config.protocol ?? 'swd' %>\n",
                "-speed", "<%= config.clock ? parseInt(config.clock / 1000) : '4000' %>\n",
                "-nohalt",
                "-noir",
                "-nogui",
                "-localhostonly",
                "-port", "<%= ports.get(start_pname) %>\n",
                "<% if (config.trace && config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                "-SWOPort", "<%= config.trace?.[\"trace-port\"] ?? '5555' %>\n",
                "<% } %>",
                "<% if (config.telnet) { %>",
                "-TelnetPort", "<%= config.telnet?.port ?? '4444' %>\n",
                "<% } %>"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load+Run",
            "dependsOn": [
                "CMSIS Load",
                "CMSIS Run"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
