{
    "data": {
        "cwd": "${workspaceFolder}/<%= solution_folder %>",
        "shell": {
            "win32": {
                "executable": "cmd.exe",
                "args": [ "/d", "/c" ]
            },
            "linux": {
                "executable": "/bin/bash",
                "args": [ "-c" ]
            },
            "darwin": {
                "executable": "/bin/bash",
                "args": [ "-c" ]
            }
        },
        "program": "<%= symbol_files[0]?.file ?? '' %>",
        "programs": "<%= symbol_files.flatMap(e => (e.pname || !processors?.length) ? e : processors.map(p => ({ ...e, pname: p }))).groupedBy(v => v.pname ?? '') %>",
        "gdbServerPlugin": "${env:AVH_FVP_PLUGINS}/<%= platform === 'win32' ? 'GDBServer.dll' : 'GDBServer.so' %>",
        "modelParameters": "<%= [ ...(config['config-file'] ? ['-f', config['config-file']] : []), ...(config.args?.trim().split(/\\s+/) ?? []), ...image_files.flatMap(image => ['-a', image.file]) ] %>"
    },
    "launch": {
        "singlecore-launch": {
            "name": "Arm-FVP@pyOCD (launch)",
            "type": "gdbtarget",
            "request": "launch",
            "cwd": "<%= data.cwd %>",
            "program": "<%= data.program %>",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": false,
            "initCommands": [
                "<%= data.programs[pname]?.slice(1)?.map(p => p.file ? `add-symbol-file \"${p.file}\"\\n` : '')?.join('') %>",
                "set remote verbose-resume-supported-packet off",
                "set remote verbose-resume-packet off",
                "tbreak main"
            ],
            "target": {
                "server": "<%= config.model %>",
                "serverParameters": [
                    "-D",
                    "--plugin", "<%= data.gdbServerPlugin %>\n",
                    "-C", "GDBServer.port=<%= ports.get(pname) %>\n",
                    "<% data.modelParameters.forEach((parameter, index) => { %>",
                    "<%= parameter %><%= index + 1 < data.modelParameters.length ? '\\n' : '' %>",
                    "<% }) %>"
                ],
                "port": "\"<%= ports.get(pname) %>\""
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        },
        "singlecore-attach": {
            "name": "Arm-FVP@pyOCD (attach)",
            "type": "gdbtarget",
            "request": "attach",
            "cwd": "<%= data.cwd %>",
            "program": "<%= data.program %>",
            "gdb": "arm-none-eabi-gdb",
            "auxiliaryGdb": false,
            "initCommands": [
                "<%= data.programs[pname]?.slice(1)?.map(p => p.file ? `add-symbol-file \"${p.file}\"\\n` : '')?.join('') %>",
                "set remote verbose-resume-supported-packet off",
                "set remote verbose-resume-packet off"
            ],
            "target": {
                "port": "\"<%= ports.get(pname) %>\""
            },
            "cmsis": {
                "cbuildRunFile": "${command:cmsis-csolution.getCbuildRunFile}",
                "updateConfiguration": "auto"
            }
        }
    },
    "tasks": [
        {
            "label": "CMSIS Load",
            "type": "shell",
            "command": "echo CMSIS Load: images are loaded by the FVP model when CMSIS Run starts.",
            "options": {
                "cwd": "<%= data.cwd %>",
                "shell": "<%= data.shell[process.platform] %>"
            },
            "problemMatcher": []
        },
        {
            "label": "CMSIS Run",
            "type": "shell",
            "command": "<%= config.model %>",
            "options": {
                "cwd": "<%= data.cwd %>",
                "shell": "<%= data.shell[process.platform] %>"
            },
            "args": [
                "-D",
                "--plugin", "<%= data.gdbServerPlugin %>\n",
                "-C", "GDBServer.port=<%= ports.get(start_pname) %>\n",
                "<% data.modelParameters.forEach((parameter, index) => { %>",
                "<%= parameter %><%= index + 1 < data.modelParameters.length ? '\\n' : '' %>",
                "<% }) %>"
            ],
            "problemMatcher": []
        },
        {
            "label": "CMSIS Load+Run",
            "dependsOn": [
                "CMSIS Load",
                "CMSIS Run"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}
