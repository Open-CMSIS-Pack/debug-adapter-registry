                    "-port", "<%= ports.get(pname) %>\n",
                    "<% if (config.trace && config.trace?.[\"trace-mode\"] === 'SWO-UART') { %>",
                    "-SWOPort",
                    "<%= config.trace?.[\"trace-port\"] ?? '5555' %>\n",
                    "<% } %>",
                    "<% if (config.telnet) { %>",
                    "-TelnetPort",
                    "<%= config.telnet?.port ?? '4444' %>\n",
                    "<% } %>"
                ],
                "port": "<%= ports.get(pname) %>"
            },
            "cmsis": {
